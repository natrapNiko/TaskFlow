@model IEnumerable<TaskFlow.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<h2>Categories</h2>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Category</th>
            <th>Tasks</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cat in Model)
        {
            <tr>
                <td>@cat.Name</td>
                <td>@cat.TodoItems.Count</td>
                <td>
                    <a asp-action="Index" asp-route-categoryFilter="@cat.Id" class="btn btn-sm btn-outline-secondary">View Tasks</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary mt-2">Back to Tasks</a>
