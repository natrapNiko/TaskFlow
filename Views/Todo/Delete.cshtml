@model TaskFlow.Models.TodoItem
@{
    ViewData["Title"] = "Delete Task";
}

<h2>Delete Task</h2>

<div class="alert alert-danger">Are you sure you want to delete this task?</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Title</dt>
            <dd class="col-sm-8">@Model.Title</dd>

            <dt class="col-sm-4">Description</dt>
            <dd class="col-sm-8">@(Model.Description ?? "-")</dd>

            <dt class="col-sm-4">Due Date</dt>
            <dd class="col-sm-8">@(Model.DueDate.HasValue ? Model.DueDate.Value.ToString("yyyy-MM-dd") : "-")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
