@model TaskFlow.Models.TodoIndexViewModel
@{
    ViewData["Title"] = "My Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Tasks</h2>
    @if (Model.CategoryFilter.HasValue)
    {
        var selectedCategory = Model.Categories.FirstOrDefault(c => c.Id == Model.CategoryFilter);
        <a asp-action="Create" asp-route-categoryId="@Model.CategoryFilter" class="btn btn-primary">
            + Add Task to @selectedCategory?.Name
        </a>
    }
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-3">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search..." />
    </div>
    <div class="col-md-2">
        <select name="statusFilter" class="form-select">
            <option value="">All Status</option>
            <option value="pending" selected="@(Model.StatusFilter == "pending")">Pending</option>
            <option value="completed" selected="@(Model.StatusFilter == "completed")">Completed</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="priorityFilter" class="form-select">
            <option value="">All Priorities</option>
            @foreach (var p in Enum.GetValues<TaskFlow.Models.Priority>())
            {
                <option value="@p" selected="@(Model.PriorityFilter == p)">@p</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="categoryFilter" class="form-select">
            <option value="">All Categories</option>
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Id" selected="@(Model.CategoryFilter == c.Id)">@c.Name</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Filter</button>
    </div>
    <div class="col-md-1">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">No tasks found.</div>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Priority</th>
                <th>Category</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr class="@(item.IsCompleted ? "table-secondary" : "")">
                    <td class="@(item.IsCompleted ? "text-decoration-line-through" : "")">@item.Title</td>
                    <td>
                        @{
                            var badgeColor = item.Priority switch
                            {
                                TaskFlow.Models.Priority.High => "danger",
                                TaskFlow.Models.Priority.Medium => "warning",
                                _ => "secondary"
                            };
                        }
                        <span class="badge bg-@badgeColor">@item.Priority</span>
                    </td>
                    <td>@(item.Category?.Name ?? "-")</td>
                    <td>@(item.DueDate.HasValue ? item.DueDate.Value.ToString("yyyy-MM-dd") : "-")</td>
                    <td>
                        @if (item.IsCompleted)
                        {
                            <span class="badge bg-success">Done</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </td>
                    <td>
                        <form asp-action="ToggleComplete" asp-route-id="@item.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm @(item.IsCompleted ? "btn-outline-secondary" : "btn-outline-success")">
                                @(item.IsCompleted ? "Undo" : "Complete")
                            </button>
                        </form>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-search="@Model.Search"
                           asp-route-statusFilter="@Model.StatusFilter"
                           asp-route-priorityFilter="@Model.PriorityFilter"
                           asp-route-categoryFilter="@Model.CategoryFilter">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

<div class="mt-3">
    <a asp-action="Categories" class="btn btn-outline-secondary btn-sm">Manage Categories</a>
</div>
